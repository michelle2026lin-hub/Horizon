{
  "ai": {
    "provider": "openai",
    "model": "llama-3.1-8b-instant",
    "api_key_env": "GROQ_API_KEY",
    "base_url": "https://api.groq.com/openai/v1",
    "throttle_sec": 6,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
},,
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "selfhosted",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "automation",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
 "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK",
    "delivery": "summary",
    "platform": "feishu",
    "layout": "text",
    "languages": ["en", "zh"]
},
  "language": "zh"
}
