{
  "ai": {
    "provider": "openai",
    "model": "qwen3.7-plus-2026-05-26",
    "api_key_env": "DASHSCOPE_API_KEY",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "throttle_sec": 2,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh"]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 5,
      "min_score": 50
    },
    "github": [
      {
        "type": "trending",
        "language": "python",
        "enabled": true
      },
      {
        "type": "trending",
        "language": "typescript",
        "enabled": true
      }
    ],
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true
      },
      {
        "name": "ProductHunt",
        "url": "https://www.producthunt.com/feed",
        "enabled": true
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {"subreddit": "LocalLLaMA", "enabled": true, "sort": "hot", "fetch_limit": 10, "min_score": 50},
        {"subreddit": "automation", "enabled": true, "sort": "hot", "fetch_limit": 10, "min_score": 30},
        {"subreddit": "selfhosted", "enabled": true, "sort": "hot", "fetch_limit": 10, "min_score": 30},
        {"subreddit": "MachineLearning", "enabled": true, "sort": "hot", "fetch_limit": 10, "min_score": 50},
        {"subreddit": "opensource", "enabled": true, "sort": "hot", "fetch_limit": 10, "min_score": 30},
        {"subreddit": "artificial", "enabled": true, "sort": "hot", "fetch_limit": 10, "min_score": 30}
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 6
  },
  "enrichment": {
    "enabled": false
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK",
    "delivery": "summary",
    "platform": "feishu",
    "layout": "markdown",
    "languages": ["zh"]
  }
}
