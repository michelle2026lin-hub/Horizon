{
  "ai": {
    "provider": "openai",
    "model": "llama-3.1-8b-instant",
    "api_key_env": "GROQ_API_KEY",
    "base_url": "https://api.groq.com/openai/v1",
    "throttle_sec": 6,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "selfhosted",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "automation",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK",
    "delivery": "summary",
    "platform": "feishu",
    "layout": "markdown",
    "languages": ["en", "zh"],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    }
  },
  "language": "zh"
}
