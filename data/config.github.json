{
  "ai": {
    "provider": "openai",
    "model": "qwen3.7-plus",
    "api_key_env": "DASHSCOPE_API_KEY",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "throttle_sec": 2,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh"]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 5,
      "min_score": 50
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {"subreddit": "LocalLLaMA", "enabled": true, "sort": "hot", "fetch_limit": 15, "min_score": 50},
        {"subreddit": "selfhosted", "enabled": true, "sort": "hot", "fetch_limit": 15, "min_score": 50},
        {"subreddit": "automation", "enabled": true, "sort": "hot", "fetch_limit": 15, "min_score": 50}
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "FEISHU_WEBHOOK",
    "delivery": "summary",
    "platform": "feishu",
    "layout": "markdown",
    "languages": ["zh"]
  },
}
